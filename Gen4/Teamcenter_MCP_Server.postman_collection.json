{
	"info": {
		"_postman_id": "tc-mcp-server-tests",
		"name": "Teamcenter MCP Server",
		"description": "Test collection for the Teamcenter MCP Server.\n\nIMPORTANT: Run requests in order:\n1. Initialize (saves session ID automatically)\n2. Initialized Notification\n3. Then any tools/list or tools/call request\n\nThe session ID is stored in a collection variable and auto-injected into all subsequent requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "mcp_session_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Setup",
			"item": [
				{
					"name": "1.1 Initialize (Run First!)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Auto-save the MCP Session ID from response header",
									"var sessionId = pm.response.headers.get('Mcp-Session-Id');",
									"if (sessionId) {",
									"    pm.collectionVariables.set('mcp_session_id', sessionId);",
									"    pm.test('Session ID captured: ' + sessionId, function() {",
									"        pm.expect(sessionId).to.not.be.empty;",
									"    });",
									"} else {",
									"    // Try lowercase header name",
									"    sessionId = pm.response.headers.get('mcp-session-id');",
									"    if (sessionId) {",
									"        pm.collectionVariables.set('mcp_session_id', sessionId);",
									"        pm.test('Session ID captured: ' + sessionId, function() {",
									"            pm.expect(sessionId).to.not.be.empty;",
									"        });",
									"    } else {",
									"        pm.test('WARNING: No Mcp-Session-Id header found', function() {",
									"            pm.expect.fail('Check if server supports Streamable HTTP');",
									"        });",
									"    }",
									"}",
									"",
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains server info', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('serverInfo');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"initialize\",\n    \"params\": {\n        \"protocolVersion\": \"2025-03-26\",\n        \"capabilities\": {},\n        \"clientInfo\": {\n            \"name\": \"postman-test\",\n            \"version\": \"1.0.0\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "MCP handshake - must be run FIRST.\n\nThis initializes the session and auto-saves the Mcp-Session-Id into a collection variable for all subsequent requests."
					}
				},
				{
					"name": "1.2 Initialized Notification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"method\": \"notifications/initialized\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Tells the server the client is ready. This is a notification (no 'id' field), so you may get a 202 or empty response - that's normal."
					}
				},
				{
					"name": "1.3 Ping",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Ping response received', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('result');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 2,\n    \"method\": \"ping\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Simple ping to verify the server is alive and the session is valid."
					}
				}
			],
			"description": "Run these in order: Initialize → Initialized Notification → Ping"
		},
		{
			"name": "2. Tool Discovery",
			"item": [
				{
					"name": "2.1 List All Tools",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains tools', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('tools');",
									"});",
									"",
									"pm.test('Contains tc_search_items', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('tc_search_items');",
									"});",
									"",
									"pm.test('Contains tc_list_saved_queries', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('tc_list_saved_queries');",
									"});",
									"",
									"pm.test('Contains tc_execute_saved_query', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('tc_execute_saved_query');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 10,\n    \"method\": \"tools/list\",\n    \"params\": {}\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Lists all MCP tools registered on the server with their names, descriptions, and input schemas. This is what Copilot calls to discover available tools."
					}
				}
			]
		},
		{
			"name": "3. Tool Calls",
			"item": [
				{
					"name": "3.1 Search Items by Keyword",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains results', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('content');",
									"});",
									"",
									"pm.test('No error returned', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.not.include('\"isError\":true');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 20,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"tc_search_items\",\n        \"arguments\": {\n            \"keyword\": \"bracket\",\n            \"maxResults\": 10\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Searches Teamcenter for items matching the keyword. Edit the 'keyword' and 'maxResults' values to test different searches."
					}
				},
				{
					"name": "3.2 Search Items (no maxResults)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 21,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"tc_search_items\",\n        \"arguments\": {\n            \"keyword\": \"assembly\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Tests calling tc_search_items without the optional maxResults parameter."
					}
				},
				{
					"name": "3.3 List Saved Queries",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Contains saved queries', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('saved_queries');",
									"});",
									"",
									"pm.test('Contains __WEB_find_Items', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('__WEB_find_Items');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 30,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"tc_list_saved_queries\",\n        \"arguments\": {}\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Lists all available Teamcenter saved queries. No arguments needed."
					}
				},
				{
					"name": "3.4 Execute Saved Query",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Contains query results', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('results');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 40,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"tc_execute_saved_query\",\n        \"arguments\": {\n            \"queryName\": \"Item Name\",\n            \"criteriaJson\": \"{\\\"Name\\\": \\\"*bracket*\\\"}\",\n            \"maxResults\": 25\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Executes a specific saved query with criteria. Edit queryName and criteriaJson to test different queries."
					}
				},
				{
					"name": "3.5 Execute Saved Query (multiple criteria)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 41,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"tc_execute_saved_query\",\n        \"arguments\": {\n            \"queryName\": \"__WEB_find_Items\",\n            \"criteriaJson\": \"{\\\"Item ID\\\": \\\"000*\\\", \\\"Name\\\": \\\"*assembly*\\\"}\",\n            \"maxResults\": 10\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Tests executing a saved query with multiple criteria fields."
					}
				}
			]
		},
		{
			"name": "4. Error Handling",
			"item": [
				{
					"name": "4.1 Invalid JSON Criteria",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Returns error result', function() {",
									"    var body = pm.response.text();",
									"    pm.expect(body).to.include('error');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 50,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"tc_execute_saved_query\",\n        \"arguments\": {\n            \"queryName\": \"Item Name\",\n            \"criteriaJson\": \"not-valid-json\",\n            \"maxResults\": 5\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Tests error handling by sending invalid JSON as criteria. Server should return an error gracefully."
					}
				},
				{
					"name": "4.2 Call Non-existent Tool",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 51,\n    \"method\": \"tools/call\",\n    \"params\": {\n        \"name\": \"tc_nonexistent_tool\",\n        \"arguments\": {}\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Tests calling a tool that doesn't exist. Server should return a proper error."
					}
				},
				{
					"name": "4.3 Request Without Session ID",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 52,\n    \"method\": \"tools/list\",\n    \"params\": {}\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": ["{{base_url}}"],
							"path": ["mcp"]
						},
						"description": "Tests what happens when you skip the session ID header. Should get an error or new session."
					}
				}
			]
		}
	]
}

{
	"info": {
		"_postman_id": "kbtc-mcp-server-tests",
		"name": "KBTC Teamcenter MCP Server",
		"description": "Complete test collection for the Knorr-Bremse Teamcenter MCP Server.\n\nIMPORTANT: Run requests in order:\n1. Initialize (saves session ID automatically)\n2. Initialized Notification\n3. Then any tools/list or tools/call request\n\nThe session ID is stored in a collection variable and auto-injected into all subsequent requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "mcp_session_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "1. Setup",
			"item": [
				{
					"name": "1.1 Initialize (Run First!)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var sessionId = pm.response.headers.get('Mcp-Session-Id') || pm.response.headers.get('mcp-session-id');",
									"if (sessionId) {",
									"    pm.collectionVariables.set('mcp_session_id', sessionId);",
									"    pm.test('Session ID captured: ' + sessionId, function() {",
									"        pm.expect(sessionId).to.not.be.empty;",
									"    });",
									"} else {",
									"    pm.test('WARNING: No Mcp-Session-Id header found', function() {",
									"        pm.expect.fail('Check if server supports Streamable HTTP');",
									"    });",
									"}",
									"pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
									"pm.test('Response contains server info', function() { pm.expect(pm.response.text()).to.include('serverInfo'); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 1,\n    \"method\": \"initialize\",\n    \"params\": {\n        \"protocolVersion\": \"2025-03-26\",\n        \"capabilities\": {},\n        \"clientInfo\": {\n            \"name\": \"postman-test\",\n            \"version\": \"1.0.0\"\n        }\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"mcp"
							]
						},
						"description": "MCP handshake - must be run FIRST. Auto-saves the Mcp-Session-Id."
					}
				},
				{
					"name": "1.2 Initialized Notification",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"method\": \"notifications/initialized\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"mcp"
							]
						},
						"description": "Tells the server the client is ready. May return 202 or empty - that's normal."
					}
				},
				{
					"name": "1.3 Ping",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() { pm.response.to.have.status(200); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 2,\n    \"method\": \"ping\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"mcp"
							]
						}
					}
				}
			]
		},
		{
			"name": "2. Tool Discovery",
			"item": [
				{
					"name": "2.1 List All Tools",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
									"var body = pm.response.text();",
									"pm.test('Contains tc_search_items', function() { pm.expect(body).to.include('tc_search_items'); });",
									"pm.test('Contains tc_get_item_revision', function() { pm.expect(body).to.include('tc_get_item_revision'); });",
									"pm.test('Contains tc_get_release_status', function() { pm.expect(body).to.include('tc_get_release_status'); });",
									"pm.test('Contains tc_get_revision_history', function() { pm.expect(body).to.include('tc_get_revision_history'); });",
									"pm.test('Contains tc_get_project_linkage', function() { pm.expect(body).to.include('tc_get_project_linkage'); });",
									"pm.test('Contains tc_get_release_approvers', function() { pm.expect(body).to.include('tc_get_release_approvers'); });",
									"pm.test('Contains tc_validate_evidence_list', function() { pm.expect(body).to.include('tc_validate_evidence_list'); });",
									"pm.test('Contains tc_validate_single_document', function() { pm.expect(body).to.include('tc_validate_single_document'); });"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Accept",
								"value": "application/json, text/event-stream"
							},
							{
								"key": "Mcp-Session-Id",
								"value": "{{mcp_session_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"jsonrpc\": \"2.0\",\n    \"id\": 10,\n    \"method\": \"tools/list\",\n    \"params\": {}\n}"
						},
						"url": {
							"raw": "{{base_url}}/mcp",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"mcp"
							]
						},
						"description": "Lists all registered MCP tools. Should show 9 tools."
					}
				}
			]
